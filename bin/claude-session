#!/usr/bin/env bash
# claude-session — Claude Code wrapper with persistent session context
# Usage:
#   claude-session                        Resume with latest session context (default model)
#   claude-session --new                  Start a fresh session
#   claude-session --model opus --new     Fresh session with specific model
#   claude-session opus                   Resume with opus model (shorthand)
#   claude-session opus --new             Fresh session with opus (shorthand)
#   claude-session --list                 List available sessions
#   claude-session --load <id>            Load a specific session (date or filename)
#   claude-session --delete <id>          Delete a specific session (date or filename)
#   claude-session --help                 Show this help
#   claude-session --version              Show version
#
# Model can be specified as:
#   --model <name>    Full flag (e.g., --model claude-opus-4-6)
#   <alias>           Shorthand as first arg (opus, sonnet, haiku, best)

set -euo pipefail

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

CLAUDE_BASE_DIR="$HOME/.claude"
MAX_CONTEXT_CHARS=2000
VERSION="1.1.0"

# Model alias map — shorthand names to full model identifiers
resolve_model() {
  local input="$1"
  case "$input" in
    opus|o)       echo "claude-opus-4-7" ;;
    opus4.6)      echo "claude-opus-4-6" ;;
    sonnet|s)     echo "claude-sonnet-4-6" ;;
    haiku|h)      echo "claude-haiku-4-5-20251001" ;;
    best)         echo "claude-opus-4-7" ;;
    *)            echo "$input" ;;  # pass through full model names
  esac
}

# Check if a string is a known model alias
is_model_alias() {
  local input="$1"
  case "$input" in
    opus|o|opus4.6|sonnet|s|haiku|h|best) return 0 ;;
    *) return 1 ;;
  esac
}

# Mirror Claude Code's project path encoding: /Users/foo/project → -Users-foo-project
resolve_memory_dir() {
  local cwd="$1"
  local encoded
  encoded=$(echo "$cwd" | sed 's|/|-|g')
  echo "${CLAUDE_BASE_DIR}/projects/${encoded}/memory"
}

ensure_sessions_dir() {
  local mem_dir="$1"
  local sessions_dir="${mem_dir}/sessions"
  mkdir -p "$sessions_dir"
  echo "$sessions_dir"
}

timestamp() {
  date "+%Y-%m-%d_%H%M%S"
}

date_display() {
  date "+%Y-%m-%d %H:%M:%S"
}

# Extract a markdown section from a file (## Header through next ## or EOF)
extract_section() {
  local file="$1"
  local section="$2"
  if [[ ! -f "$file" ]]; then return; fi
  # Use awk for reliable section extraction including the last section
  awk -v sec="## ${section}" '
    $0 == sec { found=1; print; next }
    found && /^## / { exit }
    found { print }
  ' "$file" 2>/dev/null || true
}

# Extract session_id from a session file's frontmatter
extract_session_id() {
  local file="$1"
  if [[ ! -f "$file" ]]; then return; fi
  grep "^session_id:" "$file" 2>/dev/null | head -1 | sed 's/^session_id: *//' || true
}

# Extract tag from a session file's frontmatter
extract_tag() {
  local file="$1"
  if [[ ! -f "$file" ]]; then return; fi
  grep "^tag:" "$file" 2>/dev/null | head -1 | sed 's/^tag: *//' || true
}

# Build the context string to inject into the system prompt
build_context() {
  local session_file="$1"

  if [[ ! -f "$session_file" ]]; then
    return
  fi

  local summary open_next decisions
  summary=$(extract_section "$session_file" "Summary")
  decisions=$(extract_section "$session_file" "Decisions")
  open_next=$(extract_section "$session_file" "Open / Next")

  # Get the session date from filename
  local basename
  basename=$(basename "$session_file" .md)
  local session_date="${basename#session_}"

  local context="[SESSION CONTEXT — Previous session from ${session_date}]
${summary}
${decisions}
${open_next}
[END SESSION CONTEXT]"

  # Truncate if too long
  if [[ ${#context} -gt $MAX_CONTEXT_CHARS ]]; then
    context="${context:0:$MAX_CONTEXT_CHARS}
...(truncated)
[END SESSION CONTEXT]"
  fi

  echo "$context"
}

# Find the most recent session file
find_latest_session() {
  local sessions_dir="$1"
  # Sort by filename (timestamp-based names sort chronologically)
  ls -1 "$sessions_dir"/session_*.md 2>/dev/null | sort | tail -1 || true
}

# ---------------------------------------------------------------------------
# Interactive menu helpers (gum with numbered-list fallback)
# ---------------------------------------------------------------------------

has_gum() {
  command -v gum &>/dev/null
}

install_gum_hint() {
  echo ""
  echo "For the best experience, install 'gum' (interactive terminal menus):"
  echo "  brew install gum        # macOS (Homebrew)"
  echo "  sudo apt install gum    # Debian/Ubuntu"
  echo "  go install github.com/charmbracelet/gum@latest"
  echo ""
  echo "Falling back to basic numbered menu..."
  echo ""
}

# menu_choose HEADER OPTION1 OPTION2 ...
# Prints the selected option to stdout. Returns 1 if user cancels.
menu_choose() {
  local header="$1"
  shift
  local options=("$@")

  if has_gum; then
    gum choose --header "$header" --cursor "> " -- "${options[@]}"
  else
    echo "$header" >&2
    local i=1
    for opt in "${options[@]}"; do
      printf "  %d) %s\n" "$i" "$opt" >&2
      ((i++))
    done
    echo "" >&2
    printf "Enter choice [1-%d] (q to cancel): " "${#options[@]}" >&2
    local choice
    read -r choice
    if [[ "$choice" == "q" || -z "$choice" ]]; then
      return 1
    fi
    if [[ "$choice" -ge 1 && "$choice" -le ${#options[@]} ]] 2>/dev/null; then
      echo "${options[$((choice - 1))]}"
    else
      echo "Invalid selection." >&2
      return 1
    fi
  fi
}

# menu_filter HEADER
# Reads options from stdin (one per line). Prints the selected line to stdout.
menu_filter() {
  local header="$1"

  if has_gum; then
    gum filter --header "$header" --height 15 --placeholder "Type to filter..."
  else
    local options=()
    while IFS= read -r line; do
      options+=("$line")
    done
    if [[ ${#options[@]} -eq 0 ]]; then
      echo "No items to display." >&2
      return 1
    fi
    menu_choose "$header" "${options[@]}"
  fi
}

# Create a new session skeleton file
create_session_file() {
  local sessions_dir="$1"
  local ts
  ts=$(timestamp)
  local file="${sessions_dir}/session_${ts}.md"
  local display_date
  display_date=$(date_display)

  cat > "$file" << EOF
---
name: Session ${ts}
description: Session started at ${display_date}
type: project
---

## Summary
[New session — in progress]

## Decisions
[None yet]

## What changed
[None yet]

## Open / Next
[To be determined]
EOF

  echo "$file"
}

# Update MEMORY.md index with a new session entry
update_memory_index() {
  local mem_dir="$1"
  local session_file="$2"
  local memory_md="${mem_dir}/MEMORY.md"
  local basename tag entry
  basename=$(basename "$session_file" .md)
  tag=$(extract_tag "$session_file")
  if [[ -n "$tag" ]]; then
    entry="- [${basename}](sessions/${basename}.md) — ${tag}"
  else
    entry="- [${basename}](sessions/${basename}.md) — session log"
  fi

  if [[ ! -f "$memory_md" ]]; then
    cat > "$memory_md" << EOF
# Memory Index

## Session Logs
${entry}
EOF
    return
  fi

  # Check if entry already exists
  if grep -qF "$basename" "$memory_md" 2>/dev/null; then
    return
  fi

  # Append under Session Logs section, or at end
  if grep -q "^## Session Logs" "$memory_md" 2>/dev/null; then
    # Insert after the Session Logs header
    sed -i '' "/^## Session Logs/a\\
${entry}" "$memory_md" 2>/dev/null || \
    sed -i "/^## Session Logs/a\\${entry}" "$memory_md" 2>/dev/null || \
    echo "$entry" >> "$memory_md"
  else
    printf "\n## Session Logs\n%s\n" "$entry" >> "$memory_md"
  fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_help() {
  cat << 'EOF'
claude-session — Claude Code with persistent session context

USAGE:
  claude-session                          Interactive menu (open existing / create new)
  claude-session --new                    Start a fresh session (skip menu)
  claude-session --model opus --new       Fresh session with opus model
  claude-session opus --new               Same thing (shorthand)
  claude-session --list                   List available session logs
  claude-session --load <id>              Load a specific session (date or partial match)
  claude-session --delete <id>            Delete a specific session (date or partial match)
  claude-session --help                   Show this help
  claude-session --version                Show version

INTERACTIVE MODE:
  Running with no arguments shows an interactive menu powered by 'gum'.
  Install gum for arrow-key navigation:  brew install gum
  Falls back to a numbered menu if gum is not installed.

MODEL SHORTCUTS:
  opus, o       → claude-opus-4-7 (latest)
  opus4.6       → claude-opus-4-6
  sonnet, s     → claude-sonnet-4-6
  haiku, h      → claude-haiku-4-5-20251001
  best          → claude-opus-4-7

  Use as first argument:    claude-session opus --new
  Or with --model flag:     claude-session --model claude-opus-4-6 --new
  Or pass full model name:  claude-session --model claude-sonnet-4-6

EXTRA FLAGS:
  Any unrecognized flags are passed through to claude.

HOW IT WORKS:
  • Sessions are stored in ~/.claude/projects/<encoded-cwd>/memory/sessions/
  • On start, the latest session's summary is injected via --append-system-prompt
  • On exit, a SessionEnd hook auto-captures what changed (requires hook setup)
  • Use --new to start fresh without loading previous context
EOF
}

cmd_list() {
  local mem_dir
  mem_dir=$(resolve_memory_dir "$(pwd)")
  local sessions_dir="${mem_dir}/sessions"

  if [[ ! -d "$sessions_dir" ]] || ! ls "$sessions_dir"/session_*.md &>/dev/null 2>&1; then
    echo "No sessions found for $(pwd)"
    echo "Start one with: claude-session --new"
    return 0
  fi

  echo "Sessions for $(pwd):"
  echo "---"
  for f in $(ls -1 "$sessions_dir"/session_*.md 2>/dev/null | sort -r); do
    local name tag desc display
    name=$(basename "$f" .md)
    tag=$(extract_tag "$f")
    desc=$(grep "^description:" "$f" 2>/dev/null | head -1 | sed 's/^description: *//' || true)
    if [[ -n "$tag" ]]; then
      display="${name#session_}  [${tag}]"
    else
      display="${name#session_}"
    fi
    printf "  %-45s  %s\n" "$display" "$desc"
  done
  echo "---"
  echo "Load one with: claude-session --load <date>"
}

cmd_new() {
  local mem_dir sessions_dir session_file
  mem_dir=$(resolve_memory_dir "$(pwd)")
  sessions_dir=$(ensure_sessions_dir "$mem_dir")
  session_file=$(create_session_file "$sessions_dir")
  update_memory_index "$mem_dir" "$session_file"

  echo "Created new session: $(basename "$session_file" .md)"
  echo "Starting Claude Code (fresh session)..."

  # Export session file path so the end hook knows which file to update
  export CLAUDE_SESSION_FILE="$session_file"
  exec claude ${@+"$@"}
}

cmd_load() {
  local pattern="$1"
  shift

  local mem_dir sessions_dir
  mem_dir=$(resolve_memory_dir "$(pwd)")
  sessions_dir="${mem_dir}/sessions"

  if [[ ! -d "$sessions_dir" ]]; then
    echo "No sessions directory found. Start with: claude-session --new"
    exit 1
  fi

  # Find matching session file
  local match
  match=$(ls -1 "$sessions_dir"/session_*"${pattern}"*.md 2>/dev/null | sort | tail -1 || true)

  if [[ -z "$match" ]]; then
    echo "No session matching '$pattern' found."
    echo "Available sessions:"
    cmd_list
    exit 1
  fi

  local context sid
  context=$(build_context "$match")
  sid=$(extract_session_id "$match")
  echo "Loading session: $(basename "$match" .md)"
  echo "Starting Claude Code..."

  export CLAUDE_SESSION_FILE="$match"
  if [[ -n "$sid" ]]; then
    if [[ -n "$context" ]]; then
      exec claude --resume "$sid" --append-system-prompt "$context" ${@+"$@"}
    else
      exec claude --resume "$sid" ${@+"$@"}
    fi
  else
    if [[ -n "$context" ]]; then
      exec claude --continue --append-system-prompt "$context" ${@+"$@"}
    else
      exec claude --continue ${@+"$@"}
    fi
  fi
}

cmd_delete() {
  local pattern="$1"

  local mem_dir sessions_dir
  mem_dir=$(resolve_memory_dir "$(pwd)")
  sessions_dir="${mem_dir}/sessions"

  if [[ ! -d "$sessions_dir" ]]; then
    echo "No sessions directory found."
    exit 1
  fi

  local match
  match=$(ls -1 "$sessions_dir"/session_*"${pattern}"*.md 2>/dev/null | sort | tail -1 || true)

  if [[ -z "$match" ]]; then
    echo "No session matching '$pattern' found."
    echo "Available sessions:"
    cmd_list
    exit 1
  fi

  local basename tag display
  basename=$(basename "$match" .md)
  tag=$(extract_tag "$match")
  if [[ -n "$tag" ]]; then
    display="${basename#session_}  [${tag}]"
  else
    display="${basename#session_}"
  fi

  printf "Delete session: %s\n" "$display"
  printf "Are you sure? [y/N] "
  read -r confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cancelled."
    return
  fi

  rm -f "$match"
  echo "Deleted: $match"

  local memory_md="${mem_dir}/MEMORY.md"
  if [[ -f "$memory_md" ]]; then
    grep -vF "$basename" "$memory_md" > "${memory_md}.tmp" 2>/dev/null && \
      mv "${memory_md}.tmp" "$memory_md" || \
      rm -f "${memory_md}.tmp"
  fi

  echo "Session removed."
}

# ---------------------------------------------------------------------------
# Interactive mode
# ---------------------------------------------------------------------------

interactive_open_session() {
  local sessions_dir="$1"

  local entries=()
  local dates=()
  for f in $(ls -1 "$sessions_dir"/session_*.md 2>/dev/null | sort -r); do
    local name tag desc display
    name=$(basename "$f" .md)
    tag=$(extract_tag "$f")
    desc=$(grep "^description:" "$f" 2>/dev/null | head -1 | sed 's/^description: *//' || true)
    local date_part="${name#session_}"
    if [[ -n "$tag" ]]; then
      display="${date_part}  [${tag}]"
    else
      display="${date_part}"
    fi
    if [[ -n "$desc" ]]; then
      display="${display}  ${desc}"
    fi
    entries+=("$display")
    dates+=("$date_part")
  done

  if [[ ${#entries[@]} -eq 0 ]]; then
    echo "No sessions found."
    return 1
  fi

  local selected
  selected=$(printf '%s\n' "${entries[@]}" | menu_filter "Select a session:") || {
    echo "Cancelled."
    return 0
  }

  local selected_date
  selected_date=$(echo "$selected" | awk '{print $1}')

  if [[ -z "$selected_date" ]]; then
    echo "Could not parse selection."
    return 1
  fi

  cmd_load "$selected_date"
}

interactive_new_session() {
  local model_choice
  model_choice=$(menu_choose "Select a model:" \
    "Opus 4.7   (claude-opus-4-7)        — latest, most capable" \
    "Opus 4.6   (claude-opus-4-6)" \
    "Sonnet 4.6 (claude-sonnet-4-6)" \
    "Haiku 4.5  (claude-haiku-4-5)       — fast, lightweight") || { echo "Cancelled."; return 0; }

  local model_flag
  case "$model_choice" in
    "Opus 4.7"*)   model_flag="claude-opus-4-7" ;;
    "Opus 4.6"*)   model_flag="claude-opus-4-6" ;;
    "Sonnet"*)     model_flag="claude-sonnet-4-6" ;;
    "Haiku"*)      model_flag="claude-haiku-4-5-20251001" ;;
    *)             model_flag="" ;;
  esac

  if [[ -n "$model_flag" ]]; then
    cmd_new --model "$model_flag"
  else
    cmd_new
  fi
}

cmd_interactive() {
  if ! has_gum; then
    install_gum_hint
  fi

  local mem_dir sessions_dir has_sessions=false
  mem_dir=$(resolve_memory_dir "$(pwd)")
  sessions_dir="${mem_dir}/sessions"

  if [[ -d "$sessions_dir" ]] && ls "$sessions_dir"/session_*.md &>/dev/null 2>&1; then
    has_sessions=true
  fi

  local action
  if [[ "$has_sessions" == true ]]; then
    action=$(menu_choose "What would you like to do?" \
      "Open an existing session" \
      "Create a new session") || { echo "Cancelled."; return 0; }
  else
    echo "No existing sessions found for $(pwd)."
    echo ""
    action="Create a new session"
  fi

  case "$action" in
    "Open an existing session")
      interactive_open_session "$sessions_dir"
      ;;
    "Create a new session")
      interactive_new_session
      ;;
  esac
}

cmd_resume() {
  local mem_dir sessions_dir latest
  mem_dir=$(resolve_memory_dir "$(pwd)")
  sessions_dir=$(ensure_sessions_dir "$mem_dir")
  latest=$(find_latest_session "$sessions_dir")

  if [[ -z "$latest" ]]; then
    echo "No previous sessions found. Starting fresh..."
    cmd_new ${@+"$@"}
    return
  fi

  local context sid
  context=$(build_context "$latest")
  sid=$(extract_session_id "$latest")
  echo "Resuming from: $(basename "$latest" .md)"
  echo "Starting Claude Code..."

  export CLAUDE_SESSION_FILE="$latest"
  if [[ -n "$sid" ]]; then
    if [[ -n "$context" ]]; then
      exec claude --resume "$sid" --append-system-prompt "$context" ${@+"$@"}
    else
      exec claude --resume "$sid" ${@+"$@"}
    fi
  else
    if [[ -n "$context" ]]; then
      exec claude --continue --append-system-prompt "$context" ${@+"$@"}
    else
      exec claude --continue ${@+"$@"}
    fi
  fi
}

# ---------------------------------------------------------------------------
# Main — parse arguments, extract --model / alias, then dispatch
# ---------------------------------------------------------------------------

main() {
  # Interactive mode: no arguments → show menu
  if [[ $# -eq 0 ]]; then
    cmd_interactive
    return
  fi

  local command=""
  local model=""
  local load_pattern=""
  local passthrough=()

  # Parse all arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cmd_help
        return
        ;;
      --version|-V)
        echo "claude-session $VERSION"
        return
        ;;
      --list|-l)
        cmd_list
        return
        ;;
      --new|-n)
        command="new"
        shift
        ;;
      --load)
        command="load"
        if [[ -z "${2:-}" ]]; then
          echo "Error: --load requires a date/pattern argument"
          echo "Usage: claude-session --load 2026-04-11"
          exit 1
        fi
        load_pattern="$2"
        shift 2
        ;;
      --delete|-d)
        command="delete"
        if [[ -z "${2:-}" ]]; then
          echo "Error: --delete requires a date/pattern argument"
          echo "Usage: claude-session --delete 2026-04-11"
          exit 1
        fi
        load_pattern="$2"
        shift 2
        ;;
      --model|-m)
        if [[ -z "${2:-}" ]]; then
          echo "Error: --model requires a model name"
          echo "Available: opus, sonnet, haiku, best (or full model ID)"
          exit 1
        fi
        model=$(resolve_model "$2")
        shift 2
        ;;
      *)
        # Check if it's a model alias as a bare first arg
        if [[ -z "$command" ]] && [[ -z "$model" ]] && is_model_alias "$1"; then
          model=$(resolve_model "$1")
          shift
        else
          # Pass through unknown flags to claude
          passthrough+=("$1")
          shift
        fi
        ;;
    esac
  done

  # Build model flags if specified
  if [[ -n "$model" ]]; then
    passthrough=("--model" "$model" "${passthrough[@]+"${passthrough[@]}"}")
  fi

  # Dispatch
  case "${command:-resume}" in
    new)
      cmd_new ${passthrough[@]+"${passthrough[@]}"}
      ;;
    load)
      cmd_load "$load_pattern" ${passthrough[@]+"${passthrough[@]}"}
      ;;
    delete)
      cmd_delete "$load_pattern"
      ;;
    resume)
      cmd_resume ${passthrough[@]+"${passthrough[@]}"}
      ;;
  esac
}

main "$@"
